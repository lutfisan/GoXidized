# GoXidized environment example.
# Copy this file to .env for local development and never commit real secrets.

# PostgreSQL metadata store. Migrations run automatically when the server starts.
GOXIDIZED_POSTGRES_DSN=postgres://goxidized:goxidized@localhost:5432/goxidized?sslmode=disable

# Optional bootstrap bearer token for first API access.
# Prefer creating hashed API tokens with: go run ./cmd/goxidized admin create-token
# Then insert token_sha256 into api_tokens.token_hash.
GOXIDIZED_BOOTSTRAP_TOKEN=change-this-bootstrap-token

# Optional HMAC key used to fingerprint redacted secret values without exposing them.
# Use a high-entropy value in production.
GOXIDIZED_REDACTION_HMAC_KEY=change-this-32-byte-or-longer-key

# Optional encrypted local credential file key.
# Must be 16, 24, or 32 bytes as raw text, hex, or base64.
GOXIDIZED_KMS_KEY=0123456789abcdef0123456789abcdef

# Optional OIDC client secret. Required only when server.auth.oidc.enabled=true.
GOXIDIZED_OIDC_CLIENT_SECRET=change-this-oidc-client-secret

# Example device credentials referenced by devices.example.csv.
LAB_XE_1_USERNAME=backup
LAB_XE_1_PASSWORD=change-me
LAB_XE_1_ENABLE_SECRET=change-me-enable

LAB_VRP_1_USERNAME=backup
LAB_VRP_1_PASSWORD=change-me
LAB_VRP_1_ENABLE_SECRET=change-me-super

# Private key auth is also supported.
# LAB_XR_1_USERNAME=backup
# LAB_XR_1_PRIVATE_KEY_PEM="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
